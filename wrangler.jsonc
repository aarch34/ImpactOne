{
    "$schema": "node_modules/wrangler/config-schema.json",
    "name": "impactone",
    "main": ".open-next/worker.js",
    "compatibility_date": "2025-09-27",
    "compatibility_flags": [
        "nodejs_compat"
    ],
    "assets": {
        "directory": ".open-next/assets"
    },
    "observability": {
        "enabled": true
    }
}